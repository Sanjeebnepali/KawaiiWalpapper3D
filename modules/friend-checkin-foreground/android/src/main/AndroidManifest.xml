<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <!-- Foreground service that ticks every N minutes so the JS-side Mood
       "friend asks how are you feeling?" check-in prompt fires on a reliable
       cadence while the app is closed. Uses the SPECIAL_USE FGS type (no AOSP
       type fits a generic periodic timer). Permissions below are merged into
       the app manifest at build time. -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
  <!-- Fire each check-in tick at the real wall-clock time even in Doze
       (changes/168 — Handler.postDelayed paused in deep sleep). Auto-granted on
       Android 12/13, user-grantable on 14+; the service degrades to
       setAndAllowWhileIdle when it isn't held, so it's not load-bearing. -->
  <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
  <!-- Re-arm the check-in tick after a reboot (alarms are cleared on boot). -->
  <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

  <application>
    <service
      android:name=".FriendCheckinForegroundService"
      android:exported="false"
      android:foregroundServiceType="specialUse">
      <property
        android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
        android:value="Periodic friend check-in tick for mood prompts" />
    </service>
    <!-- Receives the exact alarm; re-launches the service to emit a tick +
         re-arm. Static so it's deliverable even after the process is killed. -->
    <receiver
      android:name=".FriendCheckinAlarmReceiver"
      android:exported="false" />
    <!-- Receives BOOT_COMPLETED to re-arm after a reboot. exported=true because
         BOOT_COMPLETED is a system (protected) broadcast delivered to the app. -->
    <receiver
      android:name=".FriendCheckinBootReceiver"
      android:exported="true">
      <intent-filter>
        <action android:name="android.intent.action.BOOT_COMPLETED" />
        <action android:name="android.intent.action.QUICKBOOT_POWERON" />
      </intent-filter>
    </receiver>
  </application>
</manifest>
