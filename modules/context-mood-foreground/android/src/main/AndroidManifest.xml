<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <!-- Foreground service that ticks every N minutes so JS-side context-mood
       inference runs while the app is closed. Uses the SPECIAL_USE FGS type
       (no AOSP type fits a generic periodic timer). Permissions below are
       merged into the app manifest at build time. -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
  <!-- The service now applies the wallpaper itself on each tick (no JS), so it
       needs SET_WALLPAPER (install-time). -->
  <uses-permission android:name="android.permission.SET_WALLPAPER" />
  <!-- Fire each inference tick at the real wall-clock time even in Doze
       (changes/168 — Handler.postDelayed paused in deep sleep). Auto-granted on
       Android 12/13, user-grantable on 14+; the service degrades to
       setAndAllowWhileIdle when it isn't held, so it's not load-bearing. -->
  <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
  <!-- USE_EXACT_ALARM is AUTO-GRANTED on Android 13+ (no user step), so
       AlarmManager.canScheduleExactAlarms() returns true and every re-arm takes
       the setExactAndAllowWhileIdle path — firing to the minute even in Doze.
       SCHEDULE_EXACT_ALARM ALONE is NOT granted by default on 13/14+, so without
       this the service silently fell back to setAndAllowWhileIdle and Doze
       deferred the next tick to a maintenance window — the root cause of "mood
       only changes every 2-3h instead of every 30 min" (changes/187). -->
  <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
  <!-- Re-arm the tick alarm after a reboot (alarms are cleared on boot). -->
  <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

  <application>
    <service
      android:name=".ContextMoodForegroundService"
      android:exported="false"
      android:foregroundServiceType="specialUse">
      <property
        android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
        android:value="Periodic mood inference tick for wallpaper automation" />
    </service>
    <!-- Receives the exact alarm; re-launches the service to apply + re-arm.
         Static so it's deliverable even after the process is killed. -->
    <receiver
      android:name=".ContextMoodAlarmReceiver"
      android:exported="false" />
    <!-- Receives BOOT_COMPLETED to re-arm after a reboot. exported=true because
         BOOT_COMPLETED is a system (protected) broadcast delivered to the app. -->
    <receiver
      android:name=".ContextMoodBootReceiver"
      android:exported="true">
      <intent-filter>
        <action android:name="android.intent.action.BOOT_COMPLETED" />
        <action android:name="android.intent.action.QUICKBOOT_POWERON" />
      </intent-filter>
    </receiver>
  </application>
</manifest>
