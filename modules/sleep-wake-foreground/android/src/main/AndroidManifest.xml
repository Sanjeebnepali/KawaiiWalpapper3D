<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <!-- Any background work on Android 8+ must run inside a foreground
       service with an ongoing notification. specialUse subtype = the
       time-of-day wallpaper swap (no stock FGS type fits). POST_NOTIFICATIONS
       is a runtime permission on API 33+; SET_WALLPAPER is install-time. -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
  <uses-permission android:name="android.permission.SET_WALLPAPER" />

  <application>
    <service
      android:name=".SleepWakeForegroundService"
      android:exported="false"
      android:foregroundServiceType="specialUse">
      <property
        android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
        android:value="Time-of-day wake/sleep wallpaper while app is closed" />
    </service>
  </application>
</manifest>
