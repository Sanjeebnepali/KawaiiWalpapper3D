<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <!-- Any background work on Android 8+ must run inside a foreground
       service with an ongoing notification. specialUse subtype = the
       time-of-day wallpaper swap (no stock FGS type fits). POST_NOTIFICATIONS
       is a runtime permission on API 33+; SET_WALLPAPER is install-time. -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
  <uses-permission android:name="android.permission.SET_WALLPAPER" />
  <!-- Fire the wake/sleep swap at the exact wall-clock hour even in Doze
       (changes/162). SCHEDULE_EXACT_ALARM is auto-granted on Android 12/13 and
       user-grantable on 14+; the service degrades to setAndAllowWhileIdle when
       it isn't held, so this is not load-bearing for the build to run. -->
  <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
  <!-- USE_EXACT_ALARM is AUTO-GRANTED on Android 13+ (no user step), so
       AlarmManager.canScheduleExactAlarms() returns true and the wake/sleep
       alarm takes the setExactAndAllowWhileIdle path — firing at the exact hour
       even in Doze. SCHEDULE_EXACT_ALARM ALONE is NOT granted by default on
       13/14+, so without this the alarm fell back to setAndAllowWhileIdle and
       Doze deferred it to the next maintenance window — the root cause of "I set
       9 AM but it changes at 10 AM" (NOT a picker/timezone bug; changes/187). -->
  <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
  <!-- Re-arm the wake/sleep alarm after a reboot (alarms are cleared on boot). -->
  <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

  <application>
    <service
      android:name=".SleepWakeForegroundService"
      android:exported="false"
      android:foregroundServiceType="specialUse">
      <property
        android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
        android:value="Time-of-day wake/sleep wallpaper while app is closed" />
    </service>
    <!-- Receives the exact alarm; re-launches the service to apply + re-arm.
         Static so it's deliverable even after the process is killed. -->
    <receiver
      android:name=".SleepWakeAlarmReceiver"
      android:exported="false" />
    <!-- Receives BOOT_COMPLETED to re-arm after a reboot. exported=true because
         BOOT_COMPLETED is a system (protected) broadcast delivered to the app. -->
    <receiver
      android:name=".SleepWakeBootReceiver"
      android:exported="true">
      <intent-filter>
        <action android:name="android.intent.action.BOOT_COMPLETED" />
        <action android:name="android.intent.action.QUICKBOOT_POWERON" />
      </intent-filter>
    </receiver>
  </application>
</manifest>
