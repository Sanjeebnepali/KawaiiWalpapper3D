# Copy this file to `.env` (which is gitignored) and fill in your real values.
# Supabase Project Settings -> API -> Project URL and `anon` `public` key.
# These vars are inlined into the JS bundle at build time (Expo's `EXPO_PUBLIC_*`
# convention), so anyone who downloads the app can read them. That's fine for
# the anon key — security lives in row-level-security policies in the DB.
# NEVER put the `service_role` key here.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Hugging Face "Read" token (https://huggingface.co/settings/tokens).
# Default for AI image generation; leave blank to require users to add their own.
EXPO_PUBLIC_HF_TOKEN=your-hf-read-token
